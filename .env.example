# ─── Demo Credentials (for Quick Login in Streamlit UI) ───
DEMO_GUEST_USER=guest
DEMO_GUEST_PASS=<your_guest_password>
DEMO_HR_USER=hr_staff
DEMO_HR_PASS=<your_hr_password>
DEMO_MANAGER_USER=manager
DEMO_MANAGER_PASS=<your_manager_password>
DEMO_ADMIN_USER=admin
DEMO_ADMIN_PASS=<your_admin_password>

# ─── Database ───
POSTGRES_USER=askthecompany
POSTGRES_PASSWORD=<your_db_password>
POSTGRES_DB=askthecompany
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Qdrant ───
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── MinIO ───
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<your_minio_key>
MINIO_SECRET_KEY=<your_minio_secret>
MINIO_SECURE=false

# ─── Ollama ───
OLLAMA_HOST=http://localhost:11434
MODEL_NAME=llama3.1:8b

# ─── JWT ───
JWT_SECRET=<your_jwt_secret>
